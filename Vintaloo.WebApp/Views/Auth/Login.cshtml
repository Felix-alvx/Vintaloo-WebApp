@model Application.DTOs.LoginDTO

@{
    ViewData["Title"] = "Iniciar sesión — Vintaloo";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;1,400;1,600&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --cream:    #F2EDE4;
            --warm:     #EDE5D8;
            --terra:    #C05A35;
            --terra-dk: #9A4428;
            --terra-lt: #E8A080;
            --ink:      #1C1814;
            --muted:    #8A7E74;
            --border:   #DDD5C8;
            --success:  #4A7C59;
            --error:    #C0392B;
            --input-bg: #FDFAF6;
        }

        body {
            background: var(--cream);
            font-family: 'DM Sans', sans-serif;
            color: var(--ink);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* ── NAV ── */
        nav {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 2rem;
            height: 56px;
            border-bottom: 1px solid var(--border);
            background: var(--cream);
        }

        .nav-logo {
            display: flex;
            align-items: center;
            gap: 10px;
            text-decoration: none;
        }

        .nav-logo-icon {
            width: 30px;
            height: 30px;
            background: var(--terra);
            border-radius: 7px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .nav-logo-icon svg { width: 16px; height: 16px; fill: white; }

        .nav-logo-text {
            font-family: 'Playfair Display', serif;
            font-size: 1.1rem;
            font-weight: 600;
            color: var(--ink);
        }

        .nav-link {
            font-size: 0.82rem;
            color: var(--muted);
            text-decoration: none;
            transition: color .2s;
        }

        .nav-link:hover { color: var(--terra); }

        /* ── LAYOUT ── */
        .page {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 3rem 1rem;
        }

        .card {
            background: white;
            border: 1px solid var(--border);
            border-radius: 20px;
            padding: 2.5rem;
            width: 100%;
            max-width: 420px;
            animation: fadeUp .4s ease both;
        }

        /* ── HEADER ── */
        .card-header {
            text-align: center;
            margin-bottom: 2rem;
        }

        .card-icon {
            width: 52px;
            height: 52px;
            background: var(--terra);
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 1rem;
        }

        .card-icon svg { width: 26px; height: 26px; fill: white; }

        .card-title {
            font-family: 'Playfair Display', serif;
            font-size: 1.7rem;
            font-weight: 600;
            color: var(--ink);
            margin-bottom: .3rem;
        }

        .card-subtitle {
            font-size: 0.84rem;
            color: var(--muted);
        }

        /* ── ALERTS ── */
        .alert {
            padding: 10px 14px;
            border-radius: 8px;
            font-size: 0.84rem;
            margin-bottom: 1.2rem;
        }

        .alert-error {
            background: #FDF0ED;
            border: 1px solid var(--terra-lt);
            color: var(--terra-dk);
        }

        .alert-success {
            background: #EDF7F0;
            border: 1px solid #A8D5B5;
            color: var(--success);
        }

        /* ── FORM ── */
        .field {
            margin-bottom: 1.2rem;
        }

        .field-label {
            display: block;
            font-size: 0.72rem;
            font-weight: 500;
            letter-spacing: 0.07em;
            text-transform: uppercase;
            color: var(--muted);
            margin-bottom: 5px;
        }

        .field-input {
            width: 100%;
            padding: 11px 14px;
            border: 1.5px solid var(--border);
            border-radius: 8px;
            background: var(--input-bg);
            font-family: 'DM Sans', sans-serif;
            font-size: 0.88rem;
            color: var(--ink);
            outline: none;
            transition: border-color .2s;
        }

        .field-input:focus { border-color: var(--terra); }
        .field-input::placeholder { color: var(--muted); }

        /* Campo con botón ver contraseña */
        .pwd-wrap {
            position: relative;
        }

        .pwd-wrap .field-input {
            padding-right: 42px;
        }

        .btn-ver-pwd {
            position: absolute;
            right: 12px;
            top: 50%;
            transform: translateY(-50%);
            background: none;
            border: none;
            cursor: pointer;
            color: var(--muted);
            padding: 0;
            display: flex;
            align-items: center;
            transition: color .2s;
        }

        .btn-ver-pwd:hover { color: var(--terra); }
        .btn-ver-pwd svg { width: 18px; height: 18px; }

        .field-feedback {
            font-size: 0.75rem;
            margin-top: 4px;
            min-height: 16px;
        }

        .feedback-err { color: var(--error); }

        /* ── BOTÓN ── */
        .btn-submit {
            width: 100%;
            padding: 13px;
            background: var(--terra);
            color: white;
            border: none;
            border-radius: 10px;
            font-family: 'DM Sans', sans-serif;
            font-size: 0.92rem;
            font-weight: 500;
            cursor: pointer;
            transition: background .2s, transform .1s;
            margin-top: .5rem;
        }

        .btn-submit:hover  { background: var(--terra-dk); }
        .btn-submit:active { transform: scale(.99); }

        /* ── FOOTER ── */
        .divider {
            display: flex;
            align-items: center;
            gap: 12px;
            margin: 1.4rem 0;
            color: var(--muted);
            font-size: 0.78rem;
        }

        .divider::before,
        .divider::after {
            content: '';
            flex: 1;
            height: 1px;
            background: var(--border);
        }

        .card-footer {
            text-align: center;
            font-size: 0.82rem;
            color: var(--muted);
        }

        .card-footer a {
            color: var(--terra);
            text-decoration: none;
            font-weight: 500;
        }

        .card-footer a:hover { text-decoration: underline; }

        /* ── TAGLINE ── */
        .tagline {
            text-align: center;
            font-family: 'Playfair Display', serif;
            font-style: italic;
            font-size: 0.8rem;
            color: var(--terra-lt);
            padding: 1.5rem 0;
        }

        /* keyframes fadeUp {
            from { opacity: 0; transform: translateY(14px); }
            to   { opacity: 1; transform: translateY(0); }
                }*/
    </style>
</head>
<body>

    <!-- NAV -->
    <nav>
        <a class="nav-logo" href="/Dashboard">
            <div class="nav-logo-icon">
                <svg viewBox="0 0 24 24"><path d="M4 6h16v2H4zm2 5h12v2H6zm3 5h6v2H9z" /></svg>
            </div>
            <span class="nav-logo-text">Vintaloo</span>
        </a>
        <a class="nav-link" href="/Auth/Registrar">¿No tienes cuenta? Regístrate</a>
    </nav>

    <!-- PÁGINA -->
    <div class="page">
        <div class="card">

            <!-- Header -->
            <div class="card-header">
                <div class="card-icon">
                    <svg viewBox="0 0 24 24"><path d="M18 8h-1V6A5 5 0 0 0 7 6v2H6a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V10a2 2 0 0 0-2-2zm-6 9a2 2 0 1 1 0-4 2 2 0 0 1 0 4zm3.1-9H8.9V6a3.1 3.1 0 0 1 6.2 0v2z" /></svg>
                </div>
                <h1 class="card-title">Bienvenido</h1>
                <p class="card-subtitle">Inicia sesión para continuar</p>
            </div>

            @* Mensaje de éxito (ej: después del registro) *@
            @if (TempData["Mensaje"] != null)
            {
                <div class="alert alert-success">@TempData["Mensaje"]</div>
            }

            @* Mensaje de error *@
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-error">@TempData["Error"]</div>
            }

            @* ── FORMULARIO ── *@
            <form asp-controller="Auth" asp-action="Login" method="post">
                @Html.AntiForgeryToken()

                <!-- Correo -->
                <div class="field">
                    <label class="field-label" for="correo">Correo electrónico</label>
                    <input asp-for="Correo"
                           id="correo"
                           type="email"
                           class="field-input"
                           placeholder="tu@correo.com"
                           autocomplete="email"
                           autofocus />
                    <span asp-validation-for="Correo" class="field-feedback feedback-err"></span>
                </div>

                <!-- Contraseña -->
                <div class="field">
                    <label class="field-label" for="password">Contraseña</label>
                    <div class="pwd-wrap">
                        <input asp-for="Password"
                               id="password"
                               type="password"
                               class="field-input"
                               placeholder="Tu contraseña"
                               autocomplete="current-password" />
                        <button type="button" class="btn-ver-pwd" onclick="togglePwd()" title="Ver contraseña">
                            <svg id="iconOjo" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                                <circle cx="12" cy="12" r="3" />
                            </svg>
                        </button>
                    </div>
                    <span asp-validation-for="Password" class="field-feedback feedback-err"></span>
                </div>

                <button type="submit" class="btn-submit">
                    Iniciar sesión
                </button>
            </form>

            <div class="divider">o</div>

            <div class="card-footer">
                ¿No tienes cuenta?
                <a href="/Auth/Registrar">Regístrate gratis</a>
            </div>

        </div>
    </div>

    <p class="tagline">Vintaloo — Hecho con amor para amantes de lo antiguo.</p>

    <script>
        function togglePwd() {
            const input = document.getElementById('password');
            const icono = document.getElementById('iconOjo');
            if (input.type === 'password') {
                input.type = 'text';
                icono.innerHTML = `
                    <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/>
                    <path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/>
                    <line x1="1" y1="1" x2="23" y2="23"/>`;
            } else {
                input.type = 'password';
                icono.innerHTML = `
                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                    <circle cx="12" cy="12" r="3"/>`;
            }
        }
    </script>

</body>
</html>

