@model Application.DTOs.EditarPerfilDTO

@{
    ViewData["Title"] = "Editar perfil — Vintaloo";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/editarPerfil.css" asp-append-version="true" />
</head>
<body>

    <nav>
        <a class="nav-logo" href="/Dashboard">
            <div class="nav-logo-icon">
                <svg viewBox="0 0 24 24"><path d="M4 6h16v2H4zm2 5h12v2H6zm3 5h6v2H9z" /></svg>
            </div>
            <span class="nav-logo-text">Vintaloo</span>
        </a>
        <a class="nav-back" href="/Usuario/Perfil">← Volver al perfil</a>
    </nav>

    <div class="page">
        <div class="card">

            <div class="card-header">
                <h1 class="card-title">Editar perfil</h1>
                <p class="card-subtitle">Actualiza tu información personal</p>
            </div>

            @if (!ViewData.ModelState.IsValid)
            {
                <div style="background:#FDF0ED;border:1px solid var(--terra-lt);border-radius:8px;padding:10px 14px;font-size:.84rem;color:var(--terra-dk);margin-bottom:1.2rem">
                    @Html.ValidationSummary(false)
                </div>
            }

            <form asp-controller="Usuario" asp-action="EditarPerfil"
                  method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="IdUsuario" />

                <!-- Avatar -->
                <div class="avatar-upload">
                    <div class="avatar-preview" id="avatarPreview">
                        @{
                            var fotoActual = ViewBag.FotoActual as string;
                        }
                        @if (!string.IsNullOrEmpty(fotoActual))
                        {
                            <img id="avatarImg" src="@fotoActual" alt="Foto de perfil" />
                        }
                        else
                        {
                            <span id="avatarLetra">@(Model.Nombre?.Substring(0, 1).ToUpper() ?? "V")</span>
                        }
                    </div>
                    <div class="avatar-info">
                        <div class="avatar-label">Foto de perfil</div>
                        <div class="avatar-hint">JPG o PNG, máximo 2MB</div>
                        <label class="btn-foto">
                            Cambiar foto
                            <input type="file" name="fotoPerfil" accept="image/*"
                                   onchange="previsualizarFoto(this)" />
                        </label>
                    </div>
                </div>

                <!-- Nombre -->
                <div class="field">
                    <label class="field-label" for="nombre">Nombre</label>
                    <input asp-for="Nombre"
                           id="nombre"
                           class="field-input"
                           placeholder="Tu nombre completo" />
                    <span asp-validation-for="Nombre" class="field-feedback feedback-err"></span>
                </div>

                <!-- Teléfono y Ubicación -->
                <div class="row-2">
                    <div class="field">
                        <label class="field-label" for="telefono">Teléfono</label>
                        <input asp-for="Telefono"
                               id="telefono"
                               class="field-input"
                               placeholder="8888-8888" />
                    </div>
                    <div class="field">
                        <label class="field-label" for="ubicacion">Ubicación</label>
                        <input asp-for="Ubicacion"
                               id="ubicacion"
                               class="field-input"
                               placeholder="San José" />
                    </div>
                </div>

                <div class="btn-row">
                    <button type="submit" class="btn-guardar">Guardar cambios</button>
                    <a href="/Usuario/Perfil" class="btn-cancelar">Cancelar</a>
                </div>
            </form>

        </div>
    </div>

    <p class="tagline">Vintaloo — Hecho con amor para amantes de lo antiguo.</p>

    <script>
        function previsualizarFoto(input) {
            if (!input.files || !input.files[0]) return;
            const reader = new FileReader();
            reader.onload = e => {
                const preview = document.getElementById('avatarPreview');
                preview.innerHTML = `<img id="avatarImg" src="${e.target.result}"
                    style="width:100%;height:100%;object-fit:cover;border-radius:50%" />`;
            };
            reader.readAsDataURL(input.files[0]);
        }
    </script>

</body>
</html>

